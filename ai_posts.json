(() => {
  const state = {news:[], videos:[], gallery:[], editions:[], aiPosts:[], events:[], shown:0, pageSize:18, category:window.WV_CATEGORY||document.body.dataset.category||'', query:''};
  const repo = '/all-business-news/';
  function basePath(){ const p=location.pathname; const i=p.indexOf(repo); return i>=0 ? p.slice(0,i+repo.length) : '/'; }
  function siteLink(path){ if(!path) return '#'; if(/^https?:|^mailto:|^viber:|^tel:/.test(path)) return path; return basePath()+String(path).replace(/^\/+/,''); }
  async function getJson(path, fallback){ try{ const r=await fetch(siteLink(path),{cache:'no-store'}); if(!r.ok) throw new Error(r.status); return await r.json(); }catch(e){ return fallback; } }
  const esc=s=>String(s||'').replace(/[&<>'"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));
  const cats={poslovanje:'POSLOVANJE',ekonomija:'EKONOMIJA',financije:'FINANCIJE',trzista:'TRŽIŠTA',kultura:'KULTURA',dizajn:'DIZAJN',tehnologija:'TEHNOLOGIJA',znanost:'ZNANOST',lifestyle:'LIFESTYLE',hedonizam:'HEDONIZAM',satovi:'SATOVI',nakit:'NAKIT',pica:'PIĆA'};
  function fmt(d){ if(!d) return ''; try{return new Date(d).toLocaleDateString('hr-HR',{day:'2-digit',month:'2-digit',year:'numeric'});}catch(e){return d;} }
  function shareLinks(title, url){
    const u=encodeURIComponent(url||location.href), t=encodeURIComponent(title||document.title);
    return `<div class="share-mini"><span>DIJELI</span><a target="_blank" href="https://wa.me/?text=${t}%20${u}">WA</a><a target="_blank" href="viber://forward?text=${t}%20${u}">VIBER</a><a target="_blank" href="https://twitter.com/intent/tweet?text=${t}&url=${u}">X</a><a target="_blank" href="https://www.facebook.com/sharer/sharer.php?u=${u}">FB</a><a target="_blank" href="https://www.linkedin.com/sharing/share-offsite/?url=${u}">IN</a><a href="mailto:?subject=${t}&body=${u}">MAIL</a></div>`;
  }
  function card(n){ const url=siteLink(n.local_url||n.url||''); return `<article class="news-card"><img loading="lazy" src="${esc(n.image)}" alt=""><div class="card-body"><p class="meta">${esc(cats[n.category]||n.category||'VIJESTI')} · ${esc(n.source||'')}</p><h3><a href="${esc(url)}">${esc(n.title)}</a></h3><p>${esc(n.description||n.summary||'')}</p><div class="hero-actions"><a class="button small" href="${esc(url)}">OTVORI</a></div>${shareLinks(n.title,url)}</div></article>`; }
  function filtered(){ let arr=state.news; if(state.category) arr=arr.filter(n=>n.category===state.category); const q=(state.query||'').toLowerCase(); if(q) arr=arr.filter(n=>[n.title,n.description,n.source,n.category].join(' ').toLowerCase().includes(q)); return arr; }
  function renderNews(reset=false){ const box=document.getElementById('newsGrid'); if(!box) return; if(reset) state.shown=0; const arr=filtered(); const next=arr.slice(0,state.shown+state.pageSize); state.shown=next.length; box.innerHTML=next.map(card).join('')||'<div class="legal-box"><p>NEMA VIJESTI ZA ODABRANI FILTER.</p></div>'; const b=document.getElementById('loadMore'); if(b) b.style.display=state.shown<arr.length?'inline-flex':'none'; }
  function renderChips(){ const box=document.getElementById('quickCategories'); if(!box) return; box.innerHTML=Object.entries(cats).map(([k,v])=>`<button class="chip ${state.category===k?'active':''}" data-cat="${k}">${v}</button>`).join(''); box.querySelectorAll('.chip').forEach(b=>b.addEventListener('click',()=>{state.category=b.dataset.cat; const s=document.getElementById('categorySelect'); if(s) s.value=state.category; renderChips(); renderNews(true); renderVideos();})); }
  function renderStats(g){ const a=document.getElementById('stat-active'), s=document.getElementById('stat-sources'), t=document.getElementById('stat-time'); if(a)a.textContent=state.news.length; if(s)s.textContent=g && g.sources ? `${g.ok_sources||'-'} / ${g.sources}` : '- / -'; if(t)t.textContent=g && g.generated_at ? fmt(g.generated_at) : 'SPREMNO'; }
  function renderVideos(){ const box=document.getElementById('videoPreview'); if(!box) return; let arr=state.videos; const cat=(document.getElementById('categorySelect')?.value||state.category||''); if(cat) arr=arr.filter(v=>v.category===cat); arr=arr.slice(0,12); box.innerHTML=arr.map(v=>{ const embed=v.video_id?`<iframe class="video-frame" loading="lazy" src="https://www.youtube-nocookie.com/embed/${esc(v.video_id)}" title="${esc(v.title)}" allowfullscreen></iframe>`:`<img loading="lazy" src="${esc(v.thumbnail||'')}" alt="">`; return `<article class="video-card">${embed}<div class="card-body"><p class="meta">${esc(cats[v.category]||v.category||'VIDEO')} · ${esc(v.source||'YOUTUBE')}</p><h3>${esc(v.title)}</h3><p>${esc(v.description||'')}</p><a class="button small" href="${esc(v.url)}">OTVORI NA YOUTUBEU</a>${shareLinks(v.title,v.url)}</div></article>`}).join('')||'<div class="legal-box"><p>NEMA VIDEO ZAPISA.</p></div>'; }
  function ensureLightbox(){ let lb=document.getElementById('galleryLightbox'); if(lb) return lb; lb=document.createElement('div'); lb.id='galleryLightbox'; lb.className='gallery-lightbox'; lb.innerHTML=`<div class="gallery-lightbox-panel"><button class="gallery-lightbox-close">×</button><img class="gallery-lightbox-image" alt=""><div class="gallery-lightbox-caption"><strong></strong><p></p></div></div>`; document.body.appendChild(lb); const close=()=>lb.classList.remove('active'); lb.querySelector('.gallery-lightbox-close').onclick=close; lb.onclick=e=>{if(e.target===lb)close();}; document.addEventListener('keydown',e=>{if(e.key==='Escape')close();}); return lb; }
  function openGallery(img,title,desc){ const lb=ensureLightbox(); lb.querySelector('img').src=img; lb.querySelector('strong').textContent=title||''; lb.querySelector('p').textContent=desc||''; lb.classList.add('active'); }
  function renderGallery(){ const box=document.getElementById('galleryGrid'); if(!box) return; const arr=state.gallery.slice(0,400); box.innerHTML=arr.map(g=>{ const img=siteLink(g.image||g.path||''); return `<article class="gallery-item"><button class="gallery-open" data-image="${esc(img)}" data-title="${esc(g.title)}" data-description="${esc(g.description||'')}"><img loading="lazy" src="${esc(img)}" alt=""></button><div><strong>${esc(g.title)}</strong><p>${esc(g.description||'')}</p>${shareLinks(g.title,img)}</div></article>`;}).join('')||'<p>GALERIJA JE PRAZNA.</p>'; box.querySelectorAll('.gallery-open').forEach(b=>b.onclick=()=>openGallery(b.dataset.image,b.dataset.title,b.dataset.description)); }
  function renderEditions(){ const box=document.getElementById('editionsGrid'); if(!box) return; const cat=box.dataset.editionCategory||''; const arr=state.editions.filter(e=>(!cat||e.category===cat)); box.innerHTML=arr.map(e=>{ const cover=siteLink(e.cover||''); const url=siteLink(e.url); const pdf=siteLink(e.pdf); return `<article class="edition-card"><a class="edition-cover" style="background-image:linear-gradient(180deg,rgba(15,23,42,.05),rgba(15,23,42,.78)),url('${esc(cover)}')" href="${esc(url)}"><span>${esc(e.category_label||'SYMBOL')}</span><strong>${esc(e.title)}</strong><small>${esc(e.date||'')}</small></a><div class="card-body"><p class="meta">${esc(e.pages)} STRANICA · ${esc(e.size_mb)} MB</p><h3>${esc(e.title)}</h3><p>${esc(e.description||'')}</p><div class="hero-actions"><a class="button small" href="${esc(url)}">LISTAJ</a><a class="button small" href="${esc(pdf)}">OTVORI PDF</a></div>${shareLinks(e.title,url)}</div></article>`; }).join('')||'<p>NEMA IZDANJA.</p>'; }
  function renderPosts(){ const box=document.getElementById('postsGrid'); if(!box) return; box.innerHTML=state.aiPosts.map(p=>`<article class="post-card"><div class="card-body"><p class="meta">${esc(p.author||'Nermin Sefić')}</p><h3>${esc(p.title)}</h3><p>${esc(p.summary||'')}</p>${shareLinks(p.title, location.href)}</div></article>`).join('')||'<div class="legal-box"><p>NEMA OBJAVA.</p></div>'; }
  function renderEvents(){ const box=document.getElementById('eventsGrid'); if(!box) return; box.innerHTML=state.events.map(e=>`<article class="event-card"><div class="card-body"><p class="meta">${esc(e.date||'')} · ${esc(e.location||'')}</p><h3>${esc(e.title)}</h3><p>${esc(e.description||'')}</p>${shareLinks(e.title, location.href)}</div></article>`).join('')||'<div class="legal-box"><p>NEMA DOGAĐANJA.</p></div>'; }
  async function init(){ const [n,v,g,e,posts,ev,gen]=await Promise.all([getJson('data/news.json',[]),getJson('data/videos.json',[]),getJson('data/manual_gallery.json',[]),getJson('data/editions.json',[]),getJson('data/ai_posts.json',[]),getJson('data/manual_events.json',[]),getJson('data/generated_at.json',{})]); state.news=Array.isArray(n)?n.filter(x=>x.image):[]; state.videos=Array.isArray(v)?v:[]; state.gallery=Array.isArray(g)?g:[]; state.editions=Array.isArray(e)?e:[]; state.aiPosts=Array.isArray(posts)?posts:[]; state.events=Array.isArray(ev)?ev:[]; renderStats(gen); renderChips(); renderNews(true); renderVideos(); renderGallery(); renderEditions(); renderPosts(); renderEvents(); const q=document.getElementById('searchInput'); if(q)q.oninput=ev=>{state.query=ev.target.value; renderNews(true);}; const s=document.getElementById('categorySelect'); if(s)s.onchange=ev=>{state.category=ev.target.value||window.WV_CATEGORY||''; renderChips(); renderNews(true); renderVideos();}; const more=document.getElementById('loadMore'); if(more)more.onclick=()=>renderNews(false); }
  document.addEventListener('DOMContentLoaded',init);
})();