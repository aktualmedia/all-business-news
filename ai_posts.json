(() => {
  const repo="/all-business-news/";
  function base(){ const p=location.pathname; const i=p.indexOf(repo); return i>=0 ? p.slice(0,i+repo.length) : "/"; }
  function site(path){ return base()+String(path).replace(/^\/+/,""); }
  function esc(s){ return String(s||"").replace(/[&<>'"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;","'":"&#39;",'"':"&quot;"}[c])); }
  async function getJson(path,fallback){ try{ const r=await fetch(site(path),{cache:"no-store"}); if(!r.ok) throw new Error(r.status); return await r.json(); }catch(e){ return fallback; } }
  function share(title){ const u=encodeURIComponent(location.href), t=encodeURIComponent(title||document.title); return `<div class="share-mini"><strong>DIJELI</strong><a target="_blank" href="https://wa.me/?text=${t}%20${u}">WA</a><a target="_blank" href="https://twitter.com/intent/tweet?text=${t}&url=${u}">X</a><a target="_blank" href="https://www.linkedin.com/sharing/share-offsite/?url=${u}">IN</a><a href="mailto:?subject=${t}&body=${u}">MAIL</a></div>`; }
  document.addEventListener("DOMContentLoaded", async()=>{ const box=document.getElementById("nerminPosts"); if(!box)return; const posts=await getJson("data/ai_posts.json",[]); box.innerHTML=(posts||[]).map(p=>`<article class="nermin-card"><p class="meta">${esc(p.author||"Nermin Sefić")} · ${esc(p.category||"komentar")}</p><h3>${esc(p.title)}</h3><p>${esc(p.summary||p.body||"")}</p>${p.body?`<p>${esc(p.body)}</p>`:""}${share(p.title)}</article>`).join("")||"<p>NEMA OBJAVA.</p>"; });
})();