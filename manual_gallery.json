:root{--bg:#f5f7fb;--paper:#fff;--ink:#0f172a;--muted:#64748b;--line:#dbe3ef;--brand:#1f3c88;--accent:#6d28d9;--gold:#f59e0b;--soft:#eef2ff;--shadow:0 18px 45px rgba(15,23,42,.08);--radius:22px}
*{box-sizing:border-box}html{scroll-behavior:smooth;scroll-padding-top:8px}body{margin:0;background:linear-gradient(180deg,#f7f9ff,#fff);color:var(--ink);font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Arial,sans-serif;line-height:1.55;overflow-x:hidden}
.site-header{background:rgba(255,255,255,.96);border-bottom:1px solid var(--line);padding:14px max(14px,calc((100vw - 1180px)/2));box-shadow:0 8px 25px rgba(15,23,42,.04)}
.brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:var(--ink);width:max-content}.brand-mark{display:grid;place-items:center;width:46px;height:46px;border-radius:14px;background:linear-gradient(135deg,var(--brand),var(--accent));color:#fff;font-weight:900}.brand strong,.top-nav a,.lang-bar a,.lang-bar span,.button,.home-button,.mobile-bottom-nav a{text-transform:uppercase;letter-spacing:.035em}.brand small{display:block;color:var(--muted);font-size:.76rem;text-transform:uppercase;letter-spacing:.08em}
.top-nav{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}.top-nav a,.lang-bar a{display:inline-flex;align-items:center;justify-content:center;min-height:34px;padding:8px 12px;background:#fff;border:1px solid var(--line);border-radius:999px;text-decoration:none;color:var(--ink);font-size:.78rem;font-weight:900;box-shadow:0 6px 18px rgba(15,23,42,.04)}.top-nav a:hover,.lang-bar a:hover,.button:hover{transform:translateY(-1px);border-color:var(--accent);color:var(--accent)}
.lang-bar{display:flex;flex-wrap:wrap;align-items:center;gap:7px;margin-top:10px}.lang-bar span{font-size:.76rem;color:#475467;font-weight:900;margin-right:2px}
.page-shell{width:min(1180px,calc(100% - 28px));margin:18px auto 34px}.hero{display:grid;grid-template-columns:1.25fr .75fr;gap:22px;padding:28px;border-radius:28px;background:linear-gradient(135deg,#1f3c88,#6d28d9 58%,#f97316);color:#fff;box-shadow:var(--shadow);min-height:0}.hero.compact{display:block}.eyebrow{margin:0 0 8px;text-transform:uppercase;letter-spacing:.14em;font-weight:900;font-size:.78rem;color:rgba(255,255,255,.9)}.hero h1{margin:0 0 10px;font-size:clamp(2rem,6vw,4.2rem);line-height:1}.lead{margin:0;color:rgba(255,255,255,.92);font-size:1.08rem;max-width:850px}.hero-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}.button,.home-button{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;padding:12px 16px;border:1px solid transparent;background:linear-gradient(135deg,var(--brand),var(--accent));color:#fff;text-decoration:none;font-weight:900;box-shadow:0 10px 24px rgba(37,99,235,.18);cursor:pointer}.button.primary{background:#fff;color:#172554}.button.small{padding:9px 13px;font-size:.8rem}.home-button{background:#fff;color:var(--brand);border-color:var(--line);box-shadow:0 10px 24px rgba(15,23,42,.05)}
.stat-grid{display:grid;gap:12px}.stat-grid div{border:1px solid rgba(255,255,255,.24);background:rgba(255,255,255,.13);border-radius:20px;padding:16px}.stat-grid strong{display:block;color:#fff;font-size:1.35rem}.stat-grid span{color:rgba(255,255,255,.86);font-weight:800;text-transform:uppercase;font-size:.76rem}
.home-highlight-grid,.news-grid,.video-grid,.gallery-grid,.symbol-grid,.edition-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px}.home-highlight-grid{margin:18px 0}.highlight-panel,.news-card,.video-card,.gallery-item,.symbol-card,.edition-card,.legal-box,.control-panel,.event-card,.post-card,.radio-card,.source-card{background:#fff;border:1px solid var(--line);border-radius:22px;box-shadow:0 14px 38px rgba(15,23,42,.05);overflow:hidden}.highlight-panel{padding:22px}.kicker{display:inline-block;background:var(--soft);color:var(--accent);padding:6px 10px;border-radius:999px;font-size:.75rem;font-weight:900;text-transform:uppercase}.highlight-panel h2,.section-head h2{margin:8px 0 8px}.highlight-panel p,.section-head p,.card-body p,.gallery-item p{color:#475467}
.mobile-category-strip{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;margin:18px 0}.mobile-category-strip a{text-decoration:none;color:var(--ink);background:#fff;border:1px solid var(--line);border-radius:18px;padding:14px;box-shadow:0 10px 24px rgba(15,23,42,.04)}.mobile-category-strip strong{display:block;text-transform:uppercase;font-size:.82rem}.mobile-category-strip span{color:var(--muted);font-weight:800;font-size:.75rem;text-transform:uppercase}
.control-panel{padding:14px;margin:18px 0}.control-row{display:flex;gap:10px;flex-wrap:wrap}.control-row input,.control-row select{flex:1 1 220px;border:1px solid var(--line);border-radius:16px;padding:14px 16px;font-size:16px;background:#fff}.chips{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}.chip{border:1px solid var(--line);border-radius:999px;padding:9px 13px;background:#fff;font-weight:800;cursor:pointer}.chip.active{background:linear-gradient(135deg,var(--brand),var(--accent));color:#fff;border-color:transparent}
.section-head{display:flex;justify-content:space-between;align-items:end;gap:16px;margin:32px 0 14px}.section-head h2{text-transform:uppercase;letter-spacing:.04em}.section-head p{margin:0;max-width:72ch}.news-card img,.gallery-item img,.symbol-card img,.edition-cover-thumb{display:block;width:100%;aspect-ratio:16/10;object-fit:cover;background:#e5e7eb}.card-body,.gallery-item div,.symbol-card-body{padding:18px}.meta{margin:0 0 7px;color:var(--muted);font-size:.76rem;font-weight:900;text-transform:uppercase;letter-spacing:.05em}.news-card h3,.video-card h3,.symbol-card h3{margin:.3rem 0 .5rem;line-height:1.25}.news-card h3 a{color:var(--ink);text-decoration:none}
.video-frame{width:100%;aspect-ratio:16/9;border:0}.gallery-item button{display:block;width:100%;padding:0;border:0;background:transparent;cursor:pointer}.gallery-lightbox{position:fixed;inset:0;display:none;align-items:center;justify-content:center;background:rgba(15,23,42,.82);z-index:100;padding:18px}.gallery-lightbox.active{display:flex}.gallery-lightbox-panel{width:min(980px,100%);max-height:92vh;overflow:auto;background:#fff;border-radius:24px;box-shadow:0 28px 70px rgba(0,0,0,.30)}.gallery-lightbox-image{display:block;width:100%;height:auto}.gallery-lightbox-caption{padding:18px 22px}.gallery-lightbox-close{position:absolute;right:22px;top:18px;width:44px;height:44px;border:0;border-radius:50%;background:#fff;font-size:1.5rem;cursor:pointer}
.edition-cover{position:relative;display:flex;min-height:310px;flex-direction:column;justify-content:flex-end;gap:8px;padding:18px;color:#fff;text-decoration:none;background:#1f3c88;background-size:cover;background-position:center}.edition-cover:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(15,23,42,.08),rgba(15,23,42,.78))}.edition-cover>*{position:relative;z-index:1}.edition-cover strong{font-size:2rem;line-height:1}.edition-detail{background:#fff;border:1px solid var(--line);border-radius:24px;padding:24px;box-shadow:var(--shadow)}.edition-hero-split{display:grid;grid-template-columns:330px 1fr;gap:24px;align-items:start}.edition-cover-thumb{border-radius:20px;box-shadow:0 16px 34px rgba(15,23,42,.15)}.edition-meta{display:flex;flex-wrap:wrap;gap:8px;margin:14px 0}.edition-meta span{background:#f8fafc;border:1px solid var(--line);border-radius:999px;padding:7px 11px;font-weight:900;color:#475467;text-transform:uppercase;font-size:.78rem}.pdf-native-frame{display:block;width:100%;height:82vh;border:1px solid var(--line);border-radius:20px;background:#fff}.native-pdf-note{margin:18px 0 12px;padding:14px;background:#f8fafc;border:1px solid var(--line);border-radius:18px;color:#475467;font-weight:800;text-transform:uppercase;font-size:.84rem}
.social-hub{display:flex;flex-wrap:wrap;gap:10px}.social-pill{display:inline-flex;align-items:center;justify-content:center;padding:12px 15px;background:#fff;border:1px solid var(--line);border-radius:999px;color:var(--brand);text-decoration:none;font-weight:900;box-shadow:0 10px 24px rgba(15,23,42,.05)}
.site-footer{width:min(1180px,calc(100% - 28px));margin:0 auto 34px;color:#64748b}.mobile-bottom-nav{display:none}
@media(max-width:900px){.hero,.edition-hero-split{grid-template-columns:1fr}.home-highlight-grid,.news-grid,.video-grid,.gallery-grid,.symbol-grid,.edition-grid{grid-template-columns:1fr 1fr}.mobile-category-strip{grid-template-columns:repeat(3,1fr)}}
@media(max-width:700px){body{padding-bottom:76px}.site-header{position:relative;padding:10px}.brand{width:100%}.brand-mark{width:40px;height:40px}.brand small{font-size:.68rem}.top-nav{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-top:8px}.top-nav a{white-space:normal;min-height:38px;text-align:center;padding:8px 5px;font-size:.68rem;line-height:1.05;border-radius:12px}.lang-bar{flex-wrap:nowrap;overflow-x:auto;gap:6px;margin:6px -2px 0;padding:4px 2px 8px;scrollbar-width:none}.lang-bar span{flex:0 0 auto;font-size:.68rem;padding:7px 4px 7px 0}.lang-bar a{flex:0 0 auto;min-width:42px;padding:6px 9px;font-size:.68rem}.page-shell{width:calc(100% - 16px);margin:10px auto 18px}.hero,.hero.compact{display:block;padding:18px;margin:8px 0 12px;border-radius:20px;min-height:0}.hero h1{font-size:clamp(1.72rem,9vw,2.8rem);line-height:1.02}.lead{font-size:1rem}.home-highlight-grid,.news-grid,.video-grid,.gallery-grid,.symbol-grid,.edition-grid,.edition-hero-split,.mobile-category-strip{grid-template-columns:1fr}.section-head{display:block;margin:22px 0 10px}.section-head h2{font-size:1.18rem;margin-bottom:4px}.control-row{display:grid;grid-template-columns:1fr}.control-row input,.control-row select,.control-row button{width:100%}.stat-grid{margin-top:12px}.pdf-native-frame{height:72vh}.mobile-bottom-nav{position:fixed;left:0;right:0;bottom:0;z-index:90;display:grid;grid-template-columns:repeat(4,1fr);background:rgba(255,255,255,.97);border-top:1px solid var(--line);box-shadow:0 -12px 34px rgba(15,23,42,.14);backdrop-filter:blur(12px)}.mobile-bottom-nav a{display:flex;align-items:center;justify-content:center;min-height:58px;padding:8px 4px;color:var(--brand);text-decoration:none;font-size:.74rem;font-weight:900;border-right:1px solid var(--line)}.mobile-bottom-nav a:last-child{border-right:0}.site-footer{margin-bottom:86px}}

/* 7.1 FIX: dijeljenje, admin, statična galerija */
.share-mini,.share-detail{display:flex;flex-wrap:wrap;gap:7px;align-items:center;margin-top:12px}
.share-mini span,.share-detail strong{font-size:.72rem;color:#64748b;font-weight:900;text-transform:uppercase;letter-spacing:.08em}
.share-mini a,.share-detail a{display:inline-flex;align-items:center;justify-content:center;min-height:30px;padding:6px 9px;border:1px solid var(--line);border-radius:999px;background:#fff;color:var(--brand);text-decoration:none;font-size:.72rem;font-weight:900}
.share-detail{padding:14px;margin-top:18px;border-top:1px solid var(--line)}
#adminStatus{font-weight:800;color:#1f3c88}
.post-card{background:#fff;border:1px solid var(--line);border-radius:22px;box-shadow:0 14px 38px rgba(15,23,42,.05);overflow:hidden}
@media(max-width:700px){.share-mini,.share-detail{gap:6px}.share-mini a,.share-detail a{font-size:.68rem;padding:6px 8px}.control-panel h2{font-size:1.1rem}}
