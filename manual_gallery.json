(() => {
  async function getJson(path,fallback){ try{ const r=await fetch("../"+path,{cache:"no-store"}); if(!r.ok) throw new Error(r.status); return await r.json(); }catch(e){ return fallback; } }
  function esc(s){ return String(s||"").replace(/[&<>'"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;","'":"&#39;",'"':"&quot;"}[c])); }
  document.addEventListener("DOMContentLoaded",async()=>{ const box=document.getElementById("radioGrid"); if(!box)return; const items=await getJson("data/radio.json",[]); box.innerHTML=(items||[]).map(r=>`<article class="radio-card"><p class="meta">RADIO STREAM</p><h3>${esc(r.title)}</h3><p>${esc(r.description||"")}</p><audio controls preload="none" src="${esc(r.stream)}"></audio><div class="hero-actions"><a class="button small" target="_blank" href="${esc(r.site||r.stream)}">OTVORI STRANICU</a></div></article>`).join("")||"<p>NEMA RADIO STREAMOVA.</p>"; });
})();